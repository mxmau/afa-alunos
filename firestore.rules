rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /afa_students/{studentId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read: if request.auth != null && (resource.data.user_id == request.auth.uid || resource.data.user_id == 'mxmau96_imported');
      allow update: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        (resource.data.user_id == 'mxmau96_imported' && request.resource.data.user_id == request.auth.uid)
      );
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
